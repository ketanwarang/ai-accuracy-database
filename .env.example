# Supabase project URL (bare URL, no /rest/v1 suffix)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon/public key — safe to expose client-side, protected by RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key — SERVER ONLY, never prefix with NEXT_PUBLIC_.
# Used by app/api/create-account to create users with a set password.
# Find it in Supabase Dashboard -> Settings -> API -> service_role key.
SUPABASE_SERVICE_ROLE_KEY=
